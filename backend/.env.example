# Backend Configuration
PORT=3001

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:0.5b

# Other supported Ollama models:
# - deepseek-coder:1.3b (better quality, needs more RAM)
# - codellama:7b (better quality, needs much more RAM)

# Groq Configuration
# Get key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional comma-separated fallback models (backend now auto-selects first available)
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,mixtral-8x7b-32768,gemma2-9b-it
